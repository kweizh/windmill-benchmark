   schema:
     $schema: 'https://json-schema.org/draft/2020-12/schema'
     type: object
     properties:
       name:
         type: string
         description: The user's name
       age:
         type: integer
         description: The user's age
     required:
       - name
       - age
   is_template: false
   tags: []
   ```

