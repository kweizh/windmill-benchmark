{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "apiUrl": {
      "type": "string",
      "description": "The base URL of the API"
    },
    "token": {
      "type": "string",
      "format": "password",
      "description": "Authentication token for the API"
    }
  },
  "required": ["apiUrl", "token"]
}
